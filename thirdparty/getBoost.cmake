]=])
endfunction()

ensure_boost_system_config("${CMAKE_INSTALL_PREFIX}")
]==])
string(CONFIGURE "${BOOST_SYSTEM_INSTALL_SCRIPT_TEMPLATE}" BOOST_SYSTEM_INSTALL_SCRIPT_CONTENT @ONLY)
set(BOOST_SYSTEM_INSTALL_SCRIPT_PATH "${CMAKE_CURRENT_BINARY_DIR}/coproto-boost-system-install.cmake")
file(WRITE "${BOOST_SYSTEM_INSTALL_SCRIPT_PATH}" "${BOOST_SYSTEM_INSTALL_SCRIPT_CONTENT}")

function(detect_boost_msvc_settings out_toolset out_cl out_vcvars out_arch out_addr_model)
    if(NOT DEFINED CMAKE_CXX_COMPILER OR CMAKE_CXX_COMPILER STREQUAL "")
        message(FATAL_ERROR "CMAKE_CXX_COMPILER is not defined for MSVC Boost bootstrap.")
    endif()

    file(TO_CMAKE_PATH "${CMAKE_CXX_COMPILER}" boost_cl)

    if(DEFINED CMAKE_VS_INSTALLATION_DIRECTORY AND NOT CMAKE_VS_INSTALLATION_DIRECTORY STREQUAL "")
        file(TO_CMAKE_PATH "${CMAKE_VS_INSTALLATION_DIRECTORY}" boost_vs_root)
        set(boost_vcvars "${boost_vs_root}/VC/Auxiliary/Build/vcvarsall.bat")
    else()
        set(boost_vcvars "${boost_cl}")
        string(REGEX REPLACE "/VC/Tools/MSVC/[^/]+/bin/Host[^/]+/[^/]+/cl(\\.exe)?$" "/VC/Auxiliary/Build/vcvarsall.bat" boost_vcvars "${boost_vcvars}")
        if(boost_vcvars STREQUAL boost_cl)
            string(REGEX REPLACE "/VC/bin(/[^/]+)?/cl(\\.exe)?$" "/VC/vcvarsall.bat" boost_vcvars "${boost_vcvars}")
        endif()
    endif()

    if(NOT EXISTS "${boost_vcvars}")
        message(FATAL_ERROR "Failed to locate vcvarsall.bat for ${boost_cl}. Tried ${boost_vcvars}")
    endif()

    if(MSVC_VERSION GREATER_EQUAL 1930)
        set(boost_toolset "14.3")
    elseif(MSVC_VERSION GREATER_EQUAL 1920)
        set(boost_toolset "14.2")
    elseif(MSVC_VERSION GREATER_EQUAL 1910)
        set(boost_toolset "14.1")
    elseif(MSVC_VERSION GREATER_EQUAL 1900)
        set(boost_toolset "14.0")
    elseif(MSVC_VERSION GREATER_EQUAL 1800)
        set(boost_toolset "12.0")
    elseif(MSVC_VERSION GREATER_EQUAL 1700)
        set(boost_toolset "11.0")
    else()
        message(FATAL_ERROR "Unsupported MSVC_VERSION=${MSVC_VERSION} for Boost bootstrap.")
    endif()

    if(DEFINED MSVC_CXX_ARCHITECTURE_ID AND NOT MSVC_CXX_ARCHITECTURE_ID STREQUAL "")
        set(boost_msvc_arch "${MSVC_CXX_ARCHITECTURE_ID}")
    elseif(CMAKE_SIZEOF_VOID_P EQUAL 8)
        set(boost_msvc_arch "x64")
    else()
        set(boost_msvc_arch "x86")
    endif()

    if(boost_msvc_arch STREQUAL "x64")
        set(boost_arch "x86")
        set(boost_addr_model "64")
    elseif(boost_msvc_arch STREQUAL "x86")
        set(boost_arch "x86")
        set(boost_addr_model "32")
    elseif(boost_msvc_arch STREQUAL "ARM64")
        set(boost_arch "arm")
        set(boost_addr_model "64")
    elseif(boost_msvc_arch STREQUAL "ARM")
        set(boost_arch "arm")
        set(boost_addr_model "32")
    else()
        message(FATAL_ERROR "Unsupported MSVC architecture '${boost_msvc_arch}' for Boost bootstrap.")
    endif()

    set(${out_toolset} "${boost_toolset}" PARENT_SCOPE)
    set(${out_cl} "${boost_cl}" PARENT_SCOPE)
    set(${out_vcvars} "${boost_vcvars}" PARENT_SCOPE)
    set(${out_arch} "${boost_arch}" PARENT_SCOPE)
    set(${out_addr_model} "${boost_addr_model}" PARENT_SCOPE)
endfunction()


if(MSVC)
    set(BOOTSTRAP "${CLONE_DIR}/bootstrap.bat")
    set(B2 "${CLONE_DIR}/b2.exe")
else()
    set(BOOTSTRAP "${CLONE_DIR}/bootstrap.sh")
    set(B2 "${CLONE_DIR}/b2")
endif()

SET(B2_ARGS 
        --with-system
        --with-thread 
        --with-atomic
        --with-filesystem
        --with-regex
        --with-date_time
        -j ${PARALLEL_FETCH})

if(MSVC)
    detect_boost_msvc_settings(BOOST_MSVC_TOOLSET BOOST_MSVC_CL BOOST_MSVC_VCVARS BOOST_MSVC_ARCH BOOST_MSVC_ADDR_MODEL)
    set(BOOST_USER_CONFIG "${CLONE_DIR}/user-config.jam")
    string(CONFIGURE [=[
import option ;
using msvc : @BOOST_MSVC_TOOLSET@ : "@BOOST_MSVC_CL@" : <setup>"@BOOST_MSVC_VCVARS@" <rewrite-setup-scripts>off ;
option.set keep-going : false ;
]=] BOOST_USER_CONFIG_CONTENT @ONLY)
    list(APPEND B2_ARGS
            --ignore-site-config
            --user-config=${BOOST_USER_CONFIG}
            )
    list(APPEND B2_ARGS 
            toolset=msvc-${BOOST_MSVC_TOOLSET}
            architecture=${BOOST_MSVC_ARCH}
            address-model=${BOOST_MSVC_ADDR_MODEL}
            )
    
    if(Boost_USE_MULTITHREADED)
        list(APPEND B2_ARGS threading=multi)
    endif()

    if(Boost_USE_STATIC_LIBS)
        list(APPEND B2_ARGS link=static)
    endif()

    if(CMAKE_BUILD_TYPE STREQUAL "Debug")
        list(APPEND B2_ARGS variant=debug)
    else()
        list(APPEND B2_ARGS variant=release)
    endif()

endif()

set(BOOST_REQUIRED_CMAKE_FILES
        "${INSTALL_DIR}/lib/cmake/Boost-${BOOST_VERSION_STR}/BoostConfig.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_headers-${BOOST_VERSION_STR}/boost_headers-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_system-${BOOST_VERSION_STR}/boost_system-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_atomic-${BOOST_VERSION_STR}/boost_atomic-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_chrono-${BOOST_VERSION_STR}/boost_chrono-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_container-${BOOST_VERSION_STR}/boost_container-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_date_time-${BOOST_VERSION_STR}/boost_date_time-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_exception-${BOOST_VERSION_STR}/boost_exception-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_filesystem-${BOOST_VERSION_STR}/boost_filesystem-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_regex-${BOOST_VERSION_STR}/boost_regex-config.cmake"
        "${INSTALL_DIR}/lib/cmake/boost_thread-${BOOST_VERSION_STR}/boost_thread-config.cmake")

set(BOOST_INSTALL_COMPLETE TRUE)
foreach(BOOST_REQUIRED_CMAKE_FILE IN LISTS BOOST_REQUIRED_CMAKE_FILES)
    if(NOT EXISTS "${BOOST_REQUIRED_CMAKE_FILE}")
        set(BOOST_INSTALL_COMPLETE FALSE)
        break()
    endif()
endforeach()


if(NOT EXISTS ${CLONE_DIR} OR NOT BOOST_INSTALL_COMPLETE)

    message("============= Building Boost =============")
    if(NOT EXISTS ${CLONE_DIR})


        message("downloading ${URL}")

        file(DOWNLOAD ${URL} ${ARCH_PATH} 
            INACTIVITY_TIMEOUT 20
            EXPECTED_HASH SHA256=${SHA256_VAL}
            STATUS BOOST_DOWNLOAD_RESULT
            SHOW_PROGRESS
            )

        list(GET ${BOOST_DOWNLOAD_RESULT} 0 BOOST_DOWNLOAD_RESULT_CODE)
        if((NOT DEFINED BOOST_DOWNLOAD_RESULT) OR BOOST_DOWNLOAD_RESULT_CODE)
            message(FATAL_ERROR "failed to download boost: ${BOOST_DOWNLOAD_RESULT}")
        endif()

        message("extracting")
        file(ARCHIVE_EXTRACT INPUT ${ARCH_PATH} DESTINATION ${COPROTO_THIRDPARTY_CLONE_DIR})
        
        file(REMOVE ${ARCH_PATH})
    endif()


    if(MSVC)
        set(B2 "${CLONE_DIR}/b2.exe")
        file(WRITE "${BOOST_USER_CONFIG}" "${BOOST_USER_CONFIG_CONTENT}")
        file(REMOVE "${CLONE_DIR}/bin.v2/project-cache.jam")
        file(REMOVE_RECURSE "${CLONE_DIR}/bin.v2/libs/config")

        list(JOIN B2_ARGS " " B2_ARGS)
        vsrun(NAME "boost-build" CMD 
            "${BOOTSTRAP} msvc\n"
            "${B2} ${B2_ARGS} install --prefix=${INSTALL_DIR}\n"
            WD ${CLONE_DIR}
            )
            
    else()
        set(B2 "${CLONE_DIR}/b2")

        run(NAME "configure" CMD "bash" "${BOOTSTRAP}" WD ${CLONE_DIR})

        if(DEFINED SUDO)
            run(NAME "build" CMD "${B2}" "${B2_ARGS}" WD ${CLONE_DIR})
        endif()

        run(NAME "install" CMD "${B2}" ${B2_ARGS} install --prefix=${INSTALL_DIR} WD ${CLONE_DIR})
    endif()



    message("log ${LOG_FILE}\n==========================================")
else()
    message("Boost already fetched. ${Boost_LIBRARIES} ")
endif()

ensure_boost_system_config("${INSTALL_DIR}")

if(MSVC)
    list(JOIN B2_ARGS " " B2_ARGS)
    install(CODE "
        if(NOT CMAKE_INSTALL_PREFIX STREQUAL \"${COPROTO_STAGE}\")

            include(${CMAKE_CURRENT_LIST_DIR}/fetch.cmake)
            vsrun(NAME install-boost CMD             
                \"${B2} ${B2_ARGS} install --prefix=\${CMAKE_INSTALL_PREFIX}\n\"
                WD ${CLONE_DIR})
            include(\"${BOOST_SYSTEM_INSTALL_SCRIPT_PATH}\")
        endif()
    ")
else()
    install(CODE "
        if(NOT CMAKE_INSTALL_PREFIX STREQUAL \"${COPROTO_STAGE}\")
            execute_process(
                COMMAND ${SUDO} \"${B2}\" ${B2_ARGS} install --prefix=\${CMAKE_INSTALL_PREFIX}
                WORKING_DIRECTORY ${CLONE_DIR}
                RESULT_VARIABLE RESULT
                COMMAND_ECHO STDOUT
            )
            include(\"${BOOST_SYSTEM_INSTALL_SCRIPT_PATH}\")
        endif()
    ")
endif()
